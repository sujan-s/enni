{
  "name": "enni",
  "version": "0.1.0",
  "description": "First-party, counter-only web analytics: a ~1KB collector, one API route handler, and a password-protected admin dashboard, storing only anonymous counters in DynamoDB.",
  "keywords": [
    "analytics",
    "privacy",
    "first-party",
    "nextjs",
    "dynamodb",
    "counters",
    "cookieless"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sujan-s/enni.git"
  },
  "homepage": "https://github.com/sujan-s/enni#readme",
  "bugs": "https://github.com/sujan-s/enni/issues",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "setup"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./vitals": {
      "types": "./dist/vitals.d.ts",
      "import": "./dist/vitals.js",
      "require": "./dist/vitals.cjs"
    },
    "./dynamo": {
      "types": "./dist/dynamo.d.ts",
      "import": "./dist/dynamo.js",
      "require": "./dist/dynamo.cjs"
    },
    "./collector.js": "./dist/collector.global.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "preview": "node scripts/preview.mjs",
    "prepublishOnly": "pnpm typecheck && pnpm build && pnpm test"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
